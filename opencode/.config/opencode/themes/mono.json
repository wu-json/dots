{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "ink": "#0B0B0D",
    "graphite": "#141417",
    "slate": "#1C1C20",
    "steel": "#2A2A2F",
    "iron": "#3A3A40",
    "ash": "#52525A",
    "silver": "#7A7A82",
    "pearl": "#A8A8AE",
    "mist": "#CFCFD3",
    "bone": "#E6E6E8",
    "chalk": "#F4F4F5",
    "signalAdd": "#8FB08F",
    "signalRemove": "#B08F8F",
    "signalAddBg": "#1A221A",
    "signalRemoveBg": "#221A1A",
    "signalWarn": "#B0A88F",
    "signalInfo": "#8FA0B0"
  },
  "theme": {
    "primary":           { "dark": "chalk",   "light": "ink"     },
    "secondary":         { "dark": "mist",    "light": "steel"   },
    "accent":            { "dark": "pearl",   "light": "iron"    },
    "error":             { "dark": "signalRemove", "light": "signalRemove" },
    "warning":           { "dark": "signalWarn",   "light": "signalWarn"   },
    "success":           { "dark": "signalAdd",    "light": "signalAdd"    },
    "info":              { "dark": "signalInfo",   "light": "signalInfo"   },

    "text":              { "dark": "bone",    "light": "ink"     },
    "textMuted":         { "dark": "silver",  "light": "ash"     },

    "background":        { "dark": "ink",     "light": "chalk"   },
    "backgroundPanel":   { "dark": "graphite","light": "bone"    },
    "backgroundElement": { "dark": "slate",   "light": "mist"    },

    "border":            { "dark": "steel",   "light": "pearl"   },
    "borderActive":      { "dark": "ash",     "light": "ash"     },
    "borderSubtle":      { "dark": "slate",   "light": "mist"    },

    "diffAdded":              { "dark": "signalAdd",    "light": "signalAdd"    },
    "diffRemoved":            { "dark": "signalRemove", "light": "signalRemove" },
    "diffContext":            { "dark": "silver",       "light": "ash"          },
    "diffHunkHeader":         { "dark": "pearl",        "light": "iron"         },
    "diffHighlightAdded":     { "dark": "signalAdd",    "light": "signalAdd"    },
    "diffHighlightRemoved":   { "dark": "signalRemove", "light": "signalRemove" },
    "diffAddedBg":            { "dark": "signalAddBg",    "light": "#E6EDE6" },
    "diffRemovedBg":          { "dark": "signalRemoveBg", "light": "#EDE6E6" },
    "diffContextBg":          { "dark": "graphite",       "light": "bone"    },
    "diffLineNumber":         { "dark": "iron",           "light": "pearl"   },
    "diffAddedLineNumberBg":  { "dark": "signalAddBg",    "light": "#E6EDE6" },
    "diffRemovedLineNumberBg":{ "dark": "signalRemoveBg", "light": "#EDE6E6" },

    "markdownText":            { "dark": "bone",   "light": "ink"   },
    "markdownHeading":         { "dark": "chalk",  "light": "ink"   },
    "markdownLink":            { "dark": "mist",   "light": "steel" },
    "markdownLinkText":        { "dark": "pearl",  "light": "iron"  },
    "markdownCode":            { "dark": "mist",   "light": "steel" },
    "markdownBlockQuote":      { "dark": "silver", "light": "ash"   },
    "markdownEmph":            { "dark": "pearl",  "light": "iron"  },
    "markdownStrong":          { "dark": "chalk",  "light": "ink"   },
    "markdownHorizontalRule":  { "dark": "iron",   "light": "pearl" },
    "markdownListItem":        { "dark": "mist",   "light": "steel" },
    "markdownListEnumeration": { "dark": "pearl",  "light": "iron"  },
    "markdownImage":           { "dark": "silver", "light": "ash"   },
    "markdownImageText":       { "dark": "pearl",  "light": "iron"  },
    "markdownCodeBlock":       { "dark": "mist",   "light": "steel" },

    "syntaxComment":     { "dark": "ash",    "light": "silver" },
    "syntaxKeyword":     { "dark": "chalk",  "light": "ink"    },
    "syntaxFunction":    { "dark": "mist",   "light": "steel"  },
    "syntaxVariable":    { "dark": "bone",   "light": "iron"   },
    "syntaxString":      { "dark": "pearl",  "light": "ash"    },
    "syntaxNumber":      { "dark": "pearl",  "light": "ash"    },
    "syntaxType":        { "dark": "mist",   "light": "steel"  },
    "syntaxOperator":    { "dark": "silver", "light": "ash"    },
    "syntaxPunctuation": { "dark": "silver", "light": "ash"    }
  }
}
