**/fish/fish_variables
**/fish/completions

**/nvim/queries/sand
*.local.*

# Ignore Claude Code files except skills and settings for security reasons
# (prevents committing session data, logs, and potentially sensitive information)
claude/.claude/*
!claude/.claude/skills
!claude/.claude/settings.json

# Same idea for pi: keep configs/extensions/themes, drop secrets and session logs
pi/.pi/agent/auth.json
pi/.pi/agent/sessions/

